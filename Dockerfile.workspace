# Neural Inverse Cloud Workspace Image
# Build: az acr build --registry neuralinverseregistry -t ni-workspace:latest -f Dockerfile.workspace .

FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update -qq && apt-get install -y \
    curl git ca-certificates python3 make g++ \
    libsecret-1-dev libkrb5-dev \
    libx11-dev libxkbfile-dev \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY . .

# Git init with a commit so the build can derive a commit hash for product.json
RUN git init && git add -A && git config user.email "build@neuralinverse.com" \
    && git config user.name "build" && git commit -m "build" --allow-empty

RUN npm config set fetch-retry-mintimeout 20000 \
    && npm config set fetch-retries 5 \
    && npm ci

ENV NODE_OPTIONS="--max-old-space-size=8192"
RUN npm run buildreact

# Patch emitError so upstream TS type errors don't abort the build
RUN sed -i 's/emitError: true, transpileOnly: false/emitError: false, transpileOnly: false/g' build/lib/compilation.js || true

# Pre-bundle LLM SDKs into a single browser-compatible ESM file.
# This avoids injecting Node-only CJS helpers (__values, __await etc.) into the
# VS Code web bundle, which causes "symbol already declared" esbuild errors.
# Output: src/vs/workbench/contrib/void/browser/llmMessage/llmSdkBundle.js
RUN npm run build-llm-bundle

# Step 1: Compile TS (with errors patched to warnings)
RUN node node_modules/.bin/gulp compile-build-without-mangling

# Step 2: Build extensions
RUN node node_modules/.bin/gulp compile-extensions-build

# Step 3: Bundle + minify
RUN node node_modules/.bin/gulp minify-vscode-reh-web

# Step 4: Package into correct directory structure (the step we were missing)
# The -ci variant skips compilation (already done) and runs: native extensions + node download + packageTask
RUN node node_modules/.bin/gulp vscode-reh-web-linux-x64-min-ci

# ---------------------------------------------------------------------------
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update -qq && apt-get install -y \
    curl git ca-certificates \
    libsecret-1-0 libkrb5-3 \
    libx11-6 libxkbfile1 libnss3 \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Ubuntu 24.04 ships with 'ubuntu' user at uid/gid 1000 — rename to 'cloud'
RUN usermod -l cloud ubuntu && groupmod -n cloud ubuntu && \
    usermod -d /home/cloud -m cloud && \
    chsh -s /bin/bash cloud

# The packageTask outputs to BUILD_ROOT (parent of /build), with correct structure:
#   /ide/out/          - bundled+minified server+browser code
#   /ide/product.json  - with commit+date injected
#   /ide/package.json  - from remote/package.json
#   /ide/node_modules/ - production deps only
#   /ide/extensions/   - built extensions
#   /ide/resources/    - favicon, icons, manifest
#   /ide/bin/          - launcher scripts
#   /ide/node          - node binary
COPY --from=builder /vscode-reh-web-linux-x64 /ide

RUN chown -R cloud:cloud /ide

USER cloud
WORKDIR /home/cloud
EXPOSE 13337

CMD ["sh", "-c", \
  "curl -fsSL \"${NEURALINVERSE_AGENT_URL:-https://cloud.neuralinverse.com}/api/v2/init-script/linux/amd64\" \
     | NEURALINVERSE_AGENT_TOKEN=\"$NEURALINVERSE_AGENT_TOKEN\" sh & \
   /ide/node /ide/out/server-main.js \
     --host 0.0.0.0 \
     --port 13337 \
     --without-connection-token \
   "]
