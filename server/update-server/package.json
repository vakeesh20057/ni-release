  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
